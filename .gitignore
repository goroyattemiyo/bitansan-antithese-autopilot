# secrets
.env
.env.*
*.pem
*.key

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# temporary image workspace
tmp/
temp/
assets/raw/

# Do not commit original raster exports.
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff

# WebP backup assets are allowed.
!assets/
!assets/webp/
!assets/webp/**/*.webp
!assets/webp/.gitkeep

# local data
*.log
.DS_Store
Thumbs.db
